# Copy to backend/.env and fill in values — RanKageShop

# Local PostgreSQL (optional):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rankageshop
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/rankageshop

# Supabase — use Session Pooler (IPv4). Direct db.*.supabase.co is IPv6-only on many networks.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
PORT=4000
JWT_SECRET=change-to-long-random-string-min-32-chars
APP_BASE_URL=http://localhost:5174
CORS_ORIGINS=http://localhost:5174,http://localhost:3000,https://rankage.shop,https://www.rankage.shop

# Google OAuth — Web client ID from Google Cloud Console (OAuth 2.0)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Optional: extra client IDs (Android/iOS) comma-separated for mobile idToken verification
# GOOGLE_CLIENT_IDS=android-client-id.apps.googleusercontent.com

# G2Bulk — required for auto game/voucher fulfillment (or set in Admin → Settings → Integrations)
G2BULK_API_KEY=your-g2bulk-api-key

# Email — cPanel / hosting (Secure SSL/TLS, recommended)
# Outgoing: rankage.shop, port 465 (SSL). Username = full email address.
# Incoming (not used by app): IMAP 993 / POP3 995
# Or configure in Admin → Settings → Integrations
SMTP_HOST=rankage.shop
SMTP_PORT=465
SMTP_USER=support@rankage.shop
SMTP_PASS=your-mailbox-password
SMTP_FROM=RanKageShop <support@rankage.shop>

NODE_ENV=development

# Web Push (VAPID) — generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@rankage.shop

# Firebase Cloud Messaging (mobile push) — single-line JSON from Firebase service account
FIREBASE_SERVICE_ACCOUNT_JSON=
